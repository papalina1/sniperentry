# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY

# ── External APIs ─────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=YOUR_BIRDEYE_KEY
JUPITER_API_KEY=

# ── Trading mode ──────────────────────────────────────────────────────────────
# Set to true only after testing in paper mode
LIVE_TRADING=false

# ── Position sizing ───────────────────────────────────────────────────────────
DEFAULT_POSITION_SIZE_SOL=0.1

# ── Telegram notifications (optional) ────────────────────────────────────────
# Leave blank to disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/solsniper.db

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
