# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Base58-encoded private key (never share this). Only required in live mode.
PRIVATE_KEY= "5sXWv74J8Kuv2vtExidJKvjqqpzUbTrD8r6wR3qkJpjGA7rzFow1r5gxve3mi6d4tQpWkvPUNDNc8Fssv6rDEBgj"

# ─── APIs ─────────────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=
# Jupiter API key is optional; leave blank for free tier
JUPITER_API_KEY= "jup_4166ddddede187b22f61869def85fc6b5726520ffe0df06c809ea59d553ee494"

# ─── Trading Mode ─────────────────────────────────────────────────────────────
# LIVE_TRADING must be explicitly set to "true" to enable real transactions.
# Default is false (paper mode only).
LIVE_TRADING=false

# ─── Position Sizing ──────────────────────────────────────────────────────────
DEFAULT_POSITION_SIZE_SOL=0.024

# ─── Risk Controls ────────────────────────────────────────────────────────────
MAX_OPEN_POSITIONS=1
# Max SOL loss allowed per calendar day before bot halts
MAX_DAILY_LOSS=0.1
# Seconds to wait between consecutive buys
COOLDOWN_SECONDS=60

# ─── Age Verification ─────────────────────────────────────────────────────────
# When false (default), tokens with estimated or unknown age are allowed through.
# Set to true to require a confirmed API timestamp — stricter but fewer candidates.
REQUIRE_VERIFIED_AGE_FOR_ENTRY=false
# When true (default), tokens with completely unknown age are allowed through
# provided they pass the stricter unknown-age filters below.
ALLOW_UNKNOWN_AGE_ENTRY=true

# ─── Hard Filters ─────────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=25000
MAX_LIQUIDITY_USD=250000
MIN_RECENT_VOLUME_USD=40000
MIN_RECENT_BUY_COUNT=35
MIN_BUY_SELL_RATIO=1.8
MAX_5M_PRICE_CHANGE_PCT=120
MAX_15M_PRICE_CHANGE_PCT=250
MAX_ESTIMATED_SLIPPAGE_PCT=12
MIN_PAIR_AGE_MINUTES=3
MAX_PAIR_AGE_MINUTES=45

# ─── Stricter Filters for Unknown-Age Tokens ──────────────────────────────────
# Applied instead of the standard thresholds above when ageState=unknown and
# ALLOW_UNKNOWN_AGE_ENTRY=true. Values must be equal to or stricter than the
# standard thresholds to compensate for the missing age confirmation.
MIN_LIQUIDITY_USD_UNKNOWN_AGE=30000
MIN_RECENT_VOLUME_USD_UNKNOWN_AGE=10000
MIN_BUY_SELL_RATIO_UNKNOWN_AGE=1.3
MAX_ESTIMATED_SLIPPAGE_PCT_UNKNOWN_AGE=12

# ─── One-Trade-Only Mode ──────────────────────────────────────────────────────
# When true (default), the bot stops completely after the first trade is fully
# closed (take-profit, stop-loss, timeout, or emergency exit). Set to false to
# run continuously.
STOP_AFTER_ONE_COMPLETED_TRADE=true

# ─── Scoring ──────────────────────────────────────────────────────────────────
MIN_SCORE=80

# ─── Exit Rules ───────────────────────────────────────────────────────────────
TARGET_MULTIPLIER=2.0
# Begin evaluating exit when price reaches this level (buffer zone start)
SELL_TRIGGER_BUFFER_LOW=1.90
# Aggressively prepare exit at this level
SELL_TRIGGER_BUFFER_HIGH=1.95
STOP_LOSS_PCT=25
MAX_HOLD_MINUTES=20
# Exit if liquidity drops by this % from entry liquidity
LIQUIDITY_DROP_EXIT_PCT=30

# ─── Execution ────────────────────────────────────────────────────────────────
# Slippage tolerance in basis points (300 = 3%)
SLIPPAGE_BPS=300
# Priority fee in microlamports to prioritize transactions
PRIORITY_FEE_LAMPORTS=100000
MAX_RETRY_COUNT=3
QUOTE_RETRY_DELAY_MS=1000

# ─── Discovery ────────────────────────────────────────────────────────────────
# How often to poll Birdeye for new tokens (ms)
DISCOVERY_INTERVAL_MS=15000
# How often to check open positions (ms)
POSITION_MONITOR_INTERVAL_MS=5000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/solsniper.db
